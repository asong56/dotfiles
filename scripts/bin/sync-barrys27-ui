#!/usr/bin/env bash
set -euo pipefail

SOURCE_URL="https://unpkg.com/@barrys27/ui/src/scss/main.scss"
DEST_DIR="static/css"
DEST_FILE="$DEST_DIR/main.scss"

# Ensure the target directory exists so repeated runs are idempotent and never fail on first use.
mkdir -p "$DEST_DIR"

curl -fsSL "$SOURCE_URL" -o "$DEST_FILE"

echo "@barrys27/ui: main.scss updated successfully."
